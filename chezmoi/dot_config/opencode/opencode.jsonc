{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": "notify",
    "permission": {
        "bash": {
            "*": "ask",
            "grep": "allow",
            "ls": "allow",
            "find": "allow",
            "head": "allow",
            "tail": "allow",
            "sort": "allow",
            "jq": "allow"
        },
        "websearch": "allow"
    }
}
