# yaml-language-server: $schema=https://aka.ms/configuration-dsc-schema/0.2
# WinGet Configuration File (DSC)
# Used on Windows Native to declaratively install packages and configure settings
# See: https://learn.microsoft.com/en-us/windows/package-manager/configuration/
# Run with: winget configure <path>

properties:
  configurationVersion: 0.2.0

  metadata:
    winget:
      processor: dscv3

  assertions:
    - resource: Microsoft.Windows.Developer/OsVersion
      directives:
        description: Verify minimum OS version (Windows 11 23H2+)
        allowPrerelease: true
      settings:
        MinVersion: "10.0.22631"

  resources:
    # --- Common Tools ---
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Git
      directives:
        securityContext: elevated
      settings:
        id: Git.Git
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: WindowsTerminal
      directives:
        securityContext: elevated
      settings:
        id: Microsoft.WindowsTerminal
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: 7zip
      directives:
        securityContext: elevated
      settings:
        id: 7zip.7zip
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Notepad++
      directives:
        securityContext: elevated
      settings:
        id: Notepad++.Notepad++
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: PowerToys
      directives:
        securityContext: elevated
      settings:
        id: Microsoft.PowerToys
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Firefox
      directives:
        securityContext: current
      settings:
        id: Mozilla.Firefox
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Obsidian
      directives:
        securityContext: current
      settings:
        id: Obsidian.Obsidian
        source: winget

    # --- System Utilities ---
    - resource: PSDscResources/WindowsOptionalFeature
      name: VirtualMachinePlatform
      directives:
        securityContext: elevated
      settings:
        Name: VirtualMachinePlatform
        Ensure: Present

    - resource: PSDscResources/WindowsOptionalFeature
      name: Microsoft-Windows-Subsystem-Linux
      directives:
        securityContext: elevated
      settings:
        Name: Microsoft-Windows-Subsystem-Linux
        Ensure: Present

    - resource: Microsoft.Windows.Developer/WindowsCapability
      name: OpenSSH.Server
      directives:
        securityContext: elevated
      settings:
        name: OpenSSH.Server~~~~0.0.1.0
        ensure: Present

{{- if has "personal" .categories }}
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Discord
      directives:
        securityContext: current
      settings:
        id: Discord.Discord
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Spotify
      directives:
        securityContext: current
      settings:
        id: Spotify.Spotify
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Stremio
      directives:
        securityContext: current
      settings:
        id: Stremio.Stremio
        source: winget
{{- end }}

{{- if has "development" .categories }}
    # --- Development Tools ---
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: cURL
      directives:
        securityContext: elevated
      settings:
        id: cURL.cURL
        source: winget
{{- end }}
