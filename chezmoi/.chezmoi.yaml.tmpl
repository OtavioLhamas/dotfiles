{{ $categories := promptMultichoiceOnce
    . "categories"
    "Machine categories(s)"
    (list "work" "personal" "gaming" "multimedia" "development")
-}}
{{- $formFactor := promptChoiceOnce
    . "form_factor" "Form factor"
    (list "desktop" "laptop" "server") -}}
{{- $de := promptChoiceOnce
    . "desktop_environment" "Desktop environment"
    (list "gnome" "cosmic" "none") -}}

data:
    categories:
{{ range $categories }}
    - {{ . }}
{{ end }}
    form_factor: {{ $formFactor }}
    desktop_environment: {{ $de }}

hooks:
    read-source-state:
        pre:
{{- if eq .chezmoi.os "linux" }}
            command: .local/share/chezmoi/chezmoi/.chezmoihooks/.ensure-pre-requisites.sh
{{- end }}
{{- if eq .chezmoi.os "windows" }}
            script: .local/share/chezmoi/chezmoi/.chezmoihooks/.ensure-pre-requisites.ps1
{{- end }}

bitwarden:
    unlock: auto

interpreters:
    ps1:
        command: "powershell"
        args: ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File"]
