# Main provisioning: mise install, WinGet DSC

$ErrorActionPreference = 'Stop'

$ProjectRoot = '{{ .chezmoi.workingTree }}'

$env:PATH = "$env:USERPROFILE\.local\bin;$env:PATH"

if (Get-Command mise -ErrorAction SilentlyContinue) {
    Write-Host 'Running mise install...'
    mise install
}

if (Get-Command winget -ErrorAction SilentlyContinue) {
    Write-Host 'Running WinGet DSC...'

    winget configure "$env:USERPROFILE\.config\winget.dsc.yaml" --accept-configuration-agreements
}
