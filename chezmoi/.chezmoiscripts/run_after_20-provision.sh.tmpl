#!/bin/bash
# Main provisioning: mise install, inventory generation, ansible execution

set -euo pipefail

PROJECT_ROOT="{{ .chezmoi.workingTree }}"
ANSIBLE_DIR="$PROJECT_ROOT/ansible"

export PATH="$HOME/.local/bin:$PATH"

# --- Run mise install ---
if command -v mise &>/dev/null; then
    echo "Running mise install..."
    mise install
fi

# --- Generate Ansible inventory ---
echo "Generating Ansible inventory..."

cat > "$ANSIBLE_DIR/inventory.yaml" <<'EOF'
# Auto-generated by chezmoi — do not edit manually
all:
  hosts:
    localhost:
      ansible_connection: local
  children:
{{ range $cat := .categories }}
    {{ $cat }}:
      hosts:
        localhost:
{{ end }}
    {{ .form_factor }}:
      hosts:
        localhost:
    {{ .desktop_environment }}:
      hosts:
        localhost:
EOF

{{ if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
# Detect Windows host IP for WSL
WINDOWS_IP=$(ip route | grep default | awk '{print $3}')
cat >> "$ANSIBLE_DIR/inventory.yaml" <<EOF
    wsl:
      hosts:
        localhost:
    windows:
      hosts:
        \${WINDOWS_IP}:
          ansible_connection: ssh
          ansible_shell_type: powershell
EOF
{{ end -}}

echo "Inventory generated at: $ANSIBLE_DIR/inventory.yaml"

{{ if eq .chezmoi.os "linux" -}}
# --- Run Ansible (Linux/WSL only) ---
# On the first bootstrap, mise is not yet activated in this environment
# so it is safer to just grab the binary than dealing with PATH and all that

ANSIBLE_GALAXY="$(mise which ansible-galaxy)"
if command -v ${ANSIBLE_GALAXY} &>/dev/null; then
    ${ANSIBLE_GALAXY} install -r ${ANSIBLE_DIR}/requirements.yaml --force
fi

ANSIBLE_PLAYBOOK="$(mise which ansible-playbook)"
if command -v ${ANSIBLE_PLAYBOOK} &>/dev/null; then
    echo "Running Ansible playbook..."
    ${ANSIBLE_PLAYBOOK} -K -i "$ANSIBLE_DIR/inventory.yaml" "$ANSIBLE_DIR/main.yaml"
fi
{{ end -}}
