# ~/.bashrc: executed by bash(1) for non-login shells.
# see /usr/share/doc/bash/examples/startup-files (in the package bash-doc)
# for examples

### Export ###

if command -v nvim &>/dev/null; then
  export EDITOR=nvim
  export VISUAL=nvim
else
  export EDITOR=vim
  export VISUAL=vim
fi

# Pager
if command -v nvim &>/dev/null; then
  export MANPAGER='nvim +"Man $*" +only'
elif command -v bat &>/dev/null; then
  export MANPAGER="bat -l man -p"
fi

# fzf
if command -v fzf &>/dev/null; then
  export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git "
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"
  export FZF_DEFAULT_OPTS="--height 50% --layout=default --border
      --color=fg:#908caa,bg:#191724,hl:#ebbcba
      --color=fg+:#e0def4,bg+:#26233a,hl+:#ebbcba
      --color=border:#403d52,header:#31748f,gutter:#191724
      --color=spinner:#f6c177,info:#9ccfd8
      --color=pointer:#c4a7e7,marker:#eb6f92,prompt:#908caa"
  if command -v bat &>/dev/null; then
    export FZF_CTRL_T_OPTS="--preview 'bat --color=always -n --line-range :500 {}'"
  fi
  if command -v eza &>/dev/null; then
    export FZF_ALT_C_OPTS="--preview 'eza --icons=always --tree --color=always {} | head -200'"
  fi
fi

### XDG base directories ###

if [[ -z "$XDG_CONFIG_HOME" ]]; then
  export XDG_CONFIG_HOME="$HOME/.config"
fi

if [[ -z "$XDG_CACHE_HOME" ]]; then
  export XDG_CACHE_HOME="$HOME/.cache"
fi

if [[ -z "$XDG_DATA_HOME" ]]; then
  export XDG_DATA_HOME="$HOME/.local/share"
fi

if [[ -z "$XDG_STATE_HOME" ]]; then
  export XDG_STATE_HOME="$HOME/.local/state"
fi

###

set -o vi

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=100000
HISTFILESIZE=200000
HISTIGNORE="ls:ls *:cd:cd *:pwd:exit:sudo reboot:history"
export PROMPT_COMMAND='history -a; history -n'

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize
shopt -s autocd

bind 'set completion-ignore-case on'

bind '"\e[1;5C": forward-word'
bind '"\e[1;5D": backward-word'
bind 'set bell-style none'

# If set, the pattern "**" used in a pathname expansion context will
# match all files and zero or more directories and subdirectories.
#shopt -s globstar

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

### Aliases ###

# folder navigation
alias ..='cd ..'
alias ...='cd ../..'
alias .3='cd ../../..'
alias .4='cd ../../../..'
alias .5='cd ../../../../..'
alias -- -='cd -'

alias df='df -h'
alias dud='du -d 1 -h'
alias free='free -m'

# confirm before overwriting something
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

if command -v nvim &>/dev/null; then
  alias nv='nvim .'
fi
if command -v vim &>/dev/null; then
  alias v='vim'
fi
if command -v lazygit &>/dev/null; then
  alias lg='lazygit'
fi
if command -v opencode &>/dev/null; then
  alias oc='opencode'
fi

# better ls
if command -v eza &>/dev/null; then
  alias ls='eza --color=always --group-directories-first --icons --hyperlink'
  alias ll='eza -lh --color=always --group-directories-first --icons --octal-permissions --hyperlink --git'
  alias la='eza -lha --color=always --group-directories-first --icons --octal-permissions --hyperlink --git'
  alias ltree='eza -lh --color=always --group-directories-first --icons --octal-permissions --hyperlink --git --tree'
fi

# better cat
if command -v bat &>/dev/null; then
  alias cat='bat'
fi

# better grep
if command -v rg &>/dev/null; then
  alias grep='rg --color=auto --smart-case'
  alias fgrep='rg --color=auto --fixed-strings --smart-case'
else
  alias grep='grep --color=auto'
  alias egrep='egrep --color=auto'
  alias fgrep='fgrep --color=auto'
fi

###############

# enable programmable completion features (you don't need to enable
# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
# sources /etc/bash.bashrc).
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

case ":$PATH:" in
  *":$HOME/.opencode/bin:"*) ;;
  *) export PATH="$HOME/.opencode/bin:$PATH" ;;
esac

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# Sourced init helpers (ported from fish conf.d/01-source.fish)
__source() { command -v "$1" &>/dev/null && eval "$("$@")"; }
__source "$HOME/.local/bin/mise" activate bash
__source zoxide init bash
__source starship init bash
__source fzf --bash
__source atuin init bash
unset -f __source

if command -v fastfetch &>/dev/null; then
    fastfetch
fi
